# Django
DJANGO_SECRET_KEY=your-secret-key-min-50-chars-use-getrandomstring-or-django-shell
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave empty for SQLite)
DJANGO_DB_ENGINE=
# DJANGO_DB_PATH=db.sqlite3

# PostgreSQL (only if DJANGO_DB_ENGINE=postgresql)
# POSTGRES_DB=wunder
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_SSLMODE=prefer

# Static (optional, for collectstatic output)
# DJANGO_STATIC_ROOT=staticfiles

# reCAPTCHA
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Email (optional)
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@example.com

# Locale
# DJANGO_LANGUAGE_CODE=ru-ru
# DJANGO_TIME_ZONE=Europe/Moscow
