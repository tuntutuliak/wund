extends  ../_skeleton

//- Includes


block variables
  - var activeCategory = 'cruises'
  - var pageName = 'Single Cruise'

block page
  // Page Header
  include ../sections/_header-thin

  +breadcrumbs({
    category: activeCategory,
    title: 'Cruise from South to North of Norway',
    path: [pageName],
    bgImage: 'bg-about-us'
  })

  // Overview
  section.section.section-sm.bg-gray-100
    .container
      // Owl Carousel
      .owl-carousel.owl-carousel-centered-pagination(
      data-items='1'
      data-sm-items='2'
      data-md-items='3'
      data-lg-items='4'
      data-dots='true'
      data-stage-padding='0'
      data-loop='false'
      data-margin='30'
      data-mouse-drag='false')
        .item
          h4.box-light-title.text-gray-800 Price
          p.box-light-text.text-primary.font-weight-regular $450
        .item
          h4.text-gray-800.box-light-title Features
          ul.list-inline-comma.list-inline-comma-default.list-comma-text
            li: a(href='#') Accommodation
            li: a(href='#') Restaurant
            li: a(href='#') Bar
            li: a(href='#') Gym
            li: a(href='#') Onboard Rock Climbing
            li: a(href='#') Excursions
            li: a(href='#') Cinema
            li: a(href='#') Water Slide
            li: a(href='#') Spa & Massage Salon
            li: a(href='#') Casino
        .item
          h4.text-gray-800.box-light-title Description
          p.list-comma-text Lorem ipsum dolor sit amet, consectetur adipisicing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua
        .item
          h4.text-gray-800.box-light-title No. of People
          p 2 Adults, 1 Children

  // Book This Cruise
  section.section.section-lg
    .container
      .row.row-50.justify-content-center.justify-content-lg-between.flex-lg-row-reverse
        .col-md-10.col-lg-5.col-xl-4: .inset-left-2
          h2.wow-outer.font-weight-bold.text-gray-800: span.wow.slideInUp Book This Cruise
          form.rd-form.booking-form
            .form-wrap.form-wrap-select.wow.fadeInLeftSmall(data-wow-delay='.2s')
              // Select 1

              input.form-input.select2-input-gray(name='find-job-location' data-minimum-results-for-search="Infinity" data-container-class='input-gray' placeholder='Date')


            .form-wrap.form-wrap-select.wow.fadeInLeftSmall(data-wow-delay='.2s')
              // Select 2
              select.form-input.select(name='find-job-location' data-minimum-results-for-search="Infinity" data-container-class='select-gray' data-dropdown-class='select-gray')
                option(value='1') Cruise Type
                option(value='2') Adventure Cruise
                option(value='3') Classic Cruise
                option(value='4') Family Cruise
            .form-group
              div
                .form-wrap.form-wrap-select.wow.fadeInLeftSmall(data-wow-delay='.2s')
                  // Select 3
                  select.form-input.select(name='find-job-location' data-minimum-results-for-search="Infinity" data-container-class='select-gray' data-dropdown-class='select-gray')
                    option(value='1') Adults
                    option(value='2') 2 Adults
                    option(value='3') 3 Adults
                    option(value='4') 4 Adults
              div
                .form-wrap.form-wrap-select.wow.fadeInLeftSmall(data-wow-delay='.2s')
                  // Select 4
                  select.form-input.select(name='find-job-location' data-minimum-results-for-search="Infinity" data-container-class='select-gray' data-dropdown-class='select-gray')
                    option(value='1') Children
                    option(value='2') 1 Child
                    option(value='3') 2 Children
                    option(value='4') 3 Children


            .form-wrap.form-wrap-button: button.button.button-block.button-primary.button-winona(data-wow-delay='.4s') Book now

        .col-md-10.col-lg-7
          +jpg('single-cruise1-668x384', 'img-responsive').wow.slideInLeft

  section.section.swiper-container.swiper-slider.swiper-slider-tiny.text-center(
  data-loop='true'
  data-slide-effect='fade'
  data-autoplay='false'
  data-simulate-touch='true')
    .swiper-wrapper
      .swiper-slide(data-slide-bg='images/single-project-slide-1-1920x760.jpg'): .swiper-slide-caption: .container
      .swiper-slide(data-slide-bg='images/single-project-slide-2-1920x760.jpg'): .swiper-slide-caption: .container
      .swiper-slide(data-slide-bg='images/single-project-slide-3-1920x760.jpg'): .swiper-slide-caption: .container
    .swiper-pagination-outer.container: .swiper-pagination.swiper-pagination-modern.swiper-pagination-marked(data-index-bullet='true')



  // Testimonials
  section.section.section-lg.bg-gray-100.text-center
    .container
      h2.wow-outer.font-weight-bold.text-gray-800: span.wow.slideInUp Testimonials
      include ../includes/_slick-widget-testimonials

  // Related Crusies
  section.section.section-lg.text-center
    .container
      h2.wow-outer.font-weight-bold.text-gray-800.title-indent: span.wow.slideInUp Related Cruises
      .row.row-50
        .col-sm-6.col-lg-4.wow-outer
          // Post Classic
          article.post-classic.wow.slideInLeft
            a.post-classic-media(href=links.post): +jpg('popular-cruises-1-370x264')
            ul.post-classic-meta
              li: a.button-winona(href='#') From $480
              li: time(datetime='2018') 7 days
            h5.post-classic-title.text-gray-800: a(href=links.post) Greece, Italy & Croatia Cruise (7 Nights)
        .col-sm-6.col-lg-4.wow-outer
          // Post Classic
          article.post-classic.wow.slideInLeft(data-wow-delay='.05s')
            a.post-classic-media(href=links.post): +jpg('popular-cruises-2-370x264')
            ul.post-classic-meta
              li: a.button-winona(href='#') From $330
              li: time(datetime='2018') 6 days
            h5.post-classic-title.text-gray-800: a(href=links.post) The Fjords and Glaciers Cruise through Norway and Scandinavia
        .col-sm-6.col-lg-4.wow-outer
          // Post Classic
          article.post-classic.wow.slideInLeft(data-wow-delay='.1s')
            a.post-classic-media(href=links.post): +jpg('popular-cruises-3-370x264')
            ul.post-classic-meta
              li: a.button-winona(href='#') From $470
              li: time(datetime='2018') 15 days
            h5.post-classic-title.text-gray-800: a(href=links.post) 15-Night Cruise: Norway, Sweden, Denmark & Finland


  include ../sections/_footer-linked

